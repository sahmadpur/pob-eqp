# =============================================================================
# POB E-Queue Platform — Environment Variables
# Copy this file to .env and fill in real values before running the project.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=pob_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=pob_eqp
POSTGRES_PORT=5432

# Full Prisma connection string (used by NestJS API)
DATABASE_URL=postgresql://pob_user:change_me_strong_password@localhost:5432/pob_eqp?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# --- JWT (generate with: openssl rand -base64 64) ---
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ME_EXPIRES_IN=30d

# --- NestJS API ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_GLOBAL_PREFIX=api/v1

# --- Next.js Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# --- AWS S3 (document storage, PDF manifests) ---
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=pob-eqp-documents
AWS_S3_REPLICA_BUCKET=pob-eqp-documents-replica
# S3 presigned URL expiry in seconds (default 900 = 15 min)
AWS_S3_URL_EXPIRY=900

# --- Firebase Cloud Messaging (push notifications) ---
FIREBASE_PROJECT_ID=pob-eqp
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_FIREBASE_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@pob-eqp.iam.gserviceaccount.com

# --- Twilio (SMS notifications) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006

# --- Nodemailer (email notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@portofbaku.az
SMTP_PASS=change_me_smtp_password
SMTP_FROM='"Port of Baku" <noreply@portofbaku.az>'

# --- Weather API (Meteomatics or OpenWeatherMap) ---
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
WEATHER_API_KEY=your_weather_api_key
WEATHER_POLL_INTERVAL_MS=1800000

# --- ASCO Vessel Feed (webhook secret for vessel ETA updates) ---
ASCO_WEBHOOK_SECRET=change_me_asco_webhook_secret
ASCO_API_URL=https://asco.az/api/vessels
ASCO_API_KEY=your_asco_api_key

# --- CIBPAY payment gateway ---
# Preprod: https://api-preprod.cibpay.co  |  Prod: https://api.cibpay.co
CIBPAY_BASE_URL=https://api-preprod.cibpay.co
CIBPAY_USERNAME=
CIBPAY_PASSWORD=
# Client certificate (.p12) — mount the file into the container, see docker-compose.yml
CIBPAY_PFX_PATH=/app/secrets/cibpay.p12
CIBPAY_PFX_PASSWORD=
CIBPAY_TERMINAL=
# Some CIBPAY terminals (e.g. millikart_test, atb) require force3d=0. Kapital / Tamkart typically use 1.
CIBPAY_FORCE_3D=1
CIBPAY_DEFAULT_CURRENCY=AZN
# Base URL the CIBPAY hosted page redirects back to (usually the web app URL)
CIBPAY_RETURN_BASE_URL=http://localhost:3000

# --- Throttling defaults ---
THROTTLE_TTL_MS=3600000
THROTTLE_LIMIT=10

# --- Datadog (APM / monitoring) ---
DD_API_KEY=your_datadog_api_key
DD_SITE=datadoghq.eu
DD_SERVICE=pob-eqp-api
DD_ENV=development
DD_VERSION=0.1.0

# --- Seed / Initial Admin User ---
SEED_ADMIN_EMAIL=admin@portofbaku.az
SEED_ADMIN_PASSWORD=Admin@1234!

# --- No-Show Fine Amount (AZN) — also stored in SystemConfig ---
NO_SHOW_FINE_AMOUNT=50

# --- Slot Reservation (minutes) ---
SLOT_RESERVATION_MINUTES=15

# --- TLS / HTTPS (production only) ---
# SSL_KEY_PATH=/etc/ssl/private/server.key
# SSL_CERT_PATH=/etc/ssl/certs/server.crt
