{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=apps/web"],
      "port": 3000
    },
    {
      "name": "API (NestJS)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=apps/api"],
      "port": 3001
    },
    {
      "name": "Docker Services (postgres + redis + mailhog)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres", "redis", "mailhog"],
      "port": 5432
    }
  ]
}
